# .env.example
# Copiez ce fichier en .env et remplissez vos vraies valeurs
# Le fichier .env ne sera JAMAIS envoyé sur GitHub (il est ignoré dans .gitignore)

# Clé API Gemini (Obligatoire)
GEMINI_API_KEY=

# Connexion Google (Optionnel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sécurité des sessions (Obligatoire en production)
# Générez une chaîne aléatoire longue (ex: openssl rand -base64 32)
SESSION_SECRET=

# URL de l'application (Obligatoire en production pour Google Auth)
# Ex: https://mon-app.run.app
APP_URL=

# Chemin de la base de données (Optionnel, par défaut: database.sqlite)
DB_PATH=
